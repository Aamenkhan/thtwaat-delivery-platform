{
  "name": "thtwaat-delivery-platform",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo run dev --filter=@repo/seller-web --filter=@repo/admin-web --filter=@repo/worker-web",
    "dev:api": "pnpm --filter @repo/api dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "dotenv -e .env -- pnpm --filter @repo/db exec prisma generate",
    "db:migrate": "dotenv -e .env -- pnpm --filter @repo/db exec prisma migrate dev",
    "db:push": "dotenv -e .env -- pnpm --filter @repo/db exec prisma db push",
    "db:seed": "dotenv -e .env -- pnpm --filter @repo/db run seed",
    "db:studio": "dotenv -e .env -- pnpm --filter @repo/db exec prisma studio",
    "db:migrate:init": "dotenv -e .env -- pnpm --filter @repo/db exec prisma migrate dev --name init",
    "db:generate:api": "pnpm --filter @repo/api db:generate"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
