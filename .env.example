# Copy to ".env" at this repo root. Root "pnpm db:*" scripts load it for Prisma (CLI cwd is packages/db).
# After schema changes: stop all Node processes using this repo (e.g. pnpm dev), then run `pnpm db:generate` (Windows may EPERM-lock the Prisma query engine).
# API
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-use-long-random-string
# Shared by apps/api and packages/db (Prisma)
DATABASE_URL="postgresql://postgres:1234@localhost:5432/thtwaat_delivery_platform"
REDIS_URL=redis://localhost:6379
# Comma-separated browser origins for Express + Socket.IO (trimmed; no spaces required).
# Local dev:
CORS_ORIGIN=http://localhost:3001,http://localhost:3002,http://localhost:3003
# Production (Render API): list every frontend origin (Vercel preview/prod, custom domains).
# Example: CORS_ORIGIN=https://seller-app.vercel.app,https://admin-app.vercel.app,https://worker-app.vercel.app
# If unset, the API reflects the request Origin (works for many setups; tighten for public APIs if needed).
# Optional: reject Socket.IO connections without a valid JWT (set to 1 in production)
# SOCKET_REQUIRE_AUTH=1
# Placeholder image when scan body omits photoUrl
# SCAN_DEFAULT_PHOTO_URL=https://your-cdn.example/scan-placeholder.png

# OTP (use real providers in production)
OTP_PEPPER=change-me-in-production

# Webhooks / API keys
WEBHOOK_SIGNING_SECRET=whsec_change-me
ADMIN_BOOTSTRAP_TOKEN=change-me-bootstrap

# Shopify integration (https://shopify.dev/docs/apps/auth/oauth)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:4000/v1/integrations/shopify/callback
# Optional override (comma-separated scopes)
# SHOPIFY_SCOPES=read_orders,write_orders,read_fulfillments,write_fulfillments

# Dashboard server-side tokens (Next.js apps)
API_INTERNAL_URL=http://localhost:4000
# Admin JWT for ops dashboards (role ADMIN)
ADMIN_API_KEY=
# Base URL encoded in shipment QR codes (defaults to API URL)
PUBLIC_APP_URL=http://localhost:4000
HUB_API_KEY=
SELLER_API_KEY=

# Next.js apps (browser → Railway API in production)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: run only Next apps (start API separately with pnpm dev:api): pnpm dev:web
# Optional: Socket.IO origin if different from API (defaults to NEXT_PUBLIC_API_URL)
# NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com
