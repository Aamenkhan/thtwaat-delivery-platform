    "lint": "echo 'no lint configured'"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@repo/db": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.10",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
