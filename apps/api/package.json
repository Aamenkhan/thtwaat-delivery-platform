{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -w exec prisma generate --schema packages/db/prisma/schema.prisma && tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "worker:integrations": "node dist/integration-worker.js",
