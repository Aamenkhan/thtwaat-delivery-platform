# Copy to apps/worker-web/.env.local for local dev. Production: see `.env.production`.
NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_SELLER_WEB_URL=http://localhost:3001
# NEXT_PUBLIC_ADMIN_WEB_URL=http://localhost:3002
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=thtwaat
# Optional: Google sign-in on worker login (must match Google Cloud OAuth client).
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Do NOT add on worker-web (unused here — seller uses Maps; API uses client secret):
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# GOOGLE_CLIENT_SECRET
