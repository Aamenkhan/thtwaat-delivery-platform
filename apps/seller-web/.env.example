# Copy to apps/seller-web/.env.local for local dev.
# Production defaults live in `.env.production` (committed) for this monorepo.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
API_INTERNAL_URL=http://localhost:4000
# Same Key ID as API RAZORPAY_KEY_ID (publishable; safe in browser). Test: rzp_test_…
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx
# Optional: cross-app login links when not in `next dev` (production builds)
# NEXT_PUBLIC_ADMIN_WEB_URL=http://localhost:3002
# NEXT_PUBLIC_WORKER_WEB_URL=http://localhost:3003
# Optional: Google Geocoding API (server-only). If unset, `/api/geocode` uses OSM Nominatim (light use only).
# GOOGLE_MAPS_GEOCODING_API_KEY=
# Optional: dedicated key for Places API (New). If unset, falls back to GOOGLE_MAPS_GEOCODING_API_KEY (enable Places on that key).
# GOOGLE_PLACES_API_KEY=
# Optional: identify your app to Nominatim (https://operations.osmfoundation.org/policies/nominatim/)
# GEOCODE_USER_AGENT=YourApp/1.0 (contact: you@example.com)
# Set to 1 to disable Nominatim when no Google key (geocode returns empty until Google is configured).
# DISABLE_NOMINATIM=0
